{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "forever-pto-docs",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  "routes": [{ "pattern": "docs.forever-pto.com", "custom_domain": true }],
  "workers_dev": true,
  "preview_urls": true
}
