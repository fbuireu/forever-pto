{
  "name": "forever-pto",
  "description": "The all-in-one tool to squish your valuable PTO days",
  "keywords": [
    "nextjs",
    "typescript",
    "css",
    "tailwind",
    "cloudflare",
    "pto",
    "time-off",
    "multi-language",
    "seo",
    "turbopack",
    "shadcn",
    "pnpm"
  ],
  "author": "Ferran Buireu <fbuireu@gmail.com>",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "engines": {
    "node": "v24.14.1"
  },
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:build": "opennextjs-cloudflare build",
    "deploy": "pnpm run cf:build && opennextjs-cloudflare deploy",
    "upload": "pnpm run cf:build && opennextjs-cloudflare upload",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "format": "biome check --write --no-errors-on-unmatched",
    "format:changed": "pnpm format --changed",
    "format:all": "pnpm format .",
    "lint": "biome lint --no-errors-on-unmatched",
    "lint:all": "pnpm lint .",
    "lint:all:fix": "pnpm lint:all --fix",
    "lint:changed": "pnpm lint --write --changed",
    "lint:ts:typecheck": "tsc --project . --noEmit",
    "test:ut": "vitest run --passWithNoTests --logHeapUsage",
    "test:ut:changed": "pnpm test:ut --bail 1",
    "test:e2e": "playwright test --pass-with-no-tests",
    "test:e2e:ui": "pnpm run test:e2e -- --ui",
    "test:e2e:changed": "pnpm run test:e2e -- --only-changed",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "1.4.0",
    "@hookform/resolvers": "5.2.2",
    "@logtail/edge": "0.5.8",
    "@logtail/next": "0.3.1",
    "@opennextjs/cloudflare": "1.19.1",
    "@react-email/components": "1.0.12",
    "@react-email/render": "2.0.6",
    "@stripe/react-stripe-js": "6.1.0",
    "@stripe/stripe-js": "9.1.0",
    "@tanstack/react-table": "8.21.3",
    "@tursodatabase/serverless": "1.0.0",
    "canvas-confetti": "1.9.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-holidays": "3.27.0",
    "driver.js": "1.4.0",
    "i18n-iso-countries": "7.14.0",
    "jose": "6.2.2",
    "lucide-react": "1.8.0",
    "motion": "12.38.0",
    "next": "16.2.3",
    "next-intl": "4.9.1",
    "next-themes": "0.4.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.72.1",
    "react-use-measure": "2.1.7",
    "recharts": "3.8.1",
    "resend": "6.11.0",
    "sonner": "2.0.7",
    "stripe": "22.0.1",
    "tailwind-merge": "3.5.0",
    "vanilla-cookieconsent": "3.1.0",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@commitlint/format": "20.5.0",
    "@commitlint/types": "20.5.0",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4.2.2",
    "@types/canvas-confetti": "1.9.0",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/ui": "4.1.4",
    "conventional-changelog-atom": "5.1.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "tailwindcss": "4.2.2",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4",
    "wrangler": "4.82.1"
  }
}
