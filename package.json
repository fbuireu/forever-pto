{
  "name": "forever-pto",
  "description": "The all-in-one tool to squish your valuable PTO days",
  "version": "1.6.0",
  "keywords": [
    "nextjs",
    "typescript",
    "css",
    "tailwind",
    "cloudflare",
    "pto",
    "time-off",
    "multi-language",
    "seo",
    "turbopack",
    "pnpm"
  ],
  "author": "Ferran Buireu <contact@forever-pto.com>",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": "26.1.0"
  },
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:build": "opennextjs-cloudflare build",
    "deploy": "pnpm run cf:build && opennextjs-cloudflare deploy",
    "upload": "pnpm run cf:build && opennextjs-cloudflare upload",
    "bones:build": "boneyard-js build",
    "bones:watch": "boneyard-js build --watch",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "format": "biome check --write --no-errors-on-unmatched",
    "format:changed": "pnpm format --changed",
    "format:all": "pnpm format .",
    "lint": "biome lint --no-errors-on-unmatched",
    "lint:all": "pnpm lint .",
    "lint:all:fix": "pnpm lint:all --fix",
    "lint:changed": "pnpm lint --write --changed",
    "lint:ts:typecheck": "tsc --project . --noEmit",
    "test:ut": "vitest run --logHeapUsage",
    "test:ut:changed": "pnpm test:ut --bail 1",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "pnpm run test:e2e -- --ui",
    "test:e2e:changed": "pnpm run test:e2e -- --only-changed",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@hookform/resolvers": "5.4.0",
    "@logtail/edge": "0.5.8",
    "@logtail/next": "0.3.1",
    "@opennextjs/cloudflare": "1.20.1",
    "@react-email/components": "1.0.12",
    "@react-email/render": "2.0.10",
    "@react-pdf/renderer": "4.5.1",
    "@stripe/react-stripe-js": "6.7.0",
    "@stripe/stripe-js": "9.9.0",
    "@tursodatabase/serverless": "1.2.3",
    "boneyard-js": "1.9.0",
    "canvas-confetti": "1.9.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-holidays": "3.32.0",
    "driver.js": "1.6.0",
    "effect": "3.21.4",
    "flag-icons": "7.5.0",
    "i18n-iso-countries": "7.14.0",
    "jose": "6.2.3",
    "lucide-react": "1.23.0",
    "motion": "12.42.2",
    "next": "16.2.10",
    "next-intl": "4.13.1",
    "next-themes": "0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.81.0",
    "react-use-measure": "2.1.7",
    "recharts": "3.9.2",
    "resend": "6.17.1",
    "sonner": "2.0.7",
    "stripe": "22.3.0",
    "tailwind-merge": "3.6.0",
    "temporal-polyfill": "1.0.1",
    "vanilla-cookieconsent": "3.1.0",
    "vaul": "1.1.2",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@commitlint/cli": "21.2.0",
    "@commitlint/config-conventional": "21.2.0",
    "@commitlint/format": "21.2.0",
    "@commitlint/types": "21.2.0",
    "@playwright/test": "1.61.1",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/npm": "13.1.5",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/canvas-confetti": "1.9.0",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/ui": "4.1.10",
    "happy-dom": "20.10.6",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "semantic-release": "25.0.5",
    "tailwindcss": "4.3.2",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "wrangler": "4.107.1"
  }
}
